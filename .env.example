# Financial Hygiene Assistant — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/financial_assistant

# Google OAuth 2.0 credentials (from console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Only this email may log in — enforced server-side after Google auth
ALLOWED_USER_EMAIL=you@example.com

# LangSmith tracing (from smith.langchain.com)
LANGSMITH_API_KEY=ls__your_langsmith_api_key

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Bearer token required on all MCP /sse and /messages requests
MCP_API_KEY=your-mcp-api-key-change-me

# ── Optional (have defaults) ─────────────────────────────────────────────────

# Browser session lifetime in days (default: 30)
# SESSION_EXPIRY_DAYS=30

# Claude model to use for analytics (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# LangSmith project name (default: financial-assistant)
# LANGSMITH_PROJECT=financial-assistant

# Logging level: DEBUG | INFO | WARNING | ERROR (default: INFO)
# LOG_LEVEL=INFO

# Set to true to bypass all auth checks in local dev (default: false)
# DISABLE_AUTH=false
